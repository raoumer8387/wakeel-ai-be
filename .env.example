# Database
# Local development (SQLite): sqlite+aiosqlite:///./sql_app.db
# Production (PostgreSQL): postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./wakeel-ai.db

# Security
JWT_SECRET=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_from_console.apps.googleusercontent.com
